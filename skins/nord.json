{
  "name": "Nord",
  "extends": "default",
  "mode": "dark",
  "variables": {
    "--bg-000": "222 16% 28%",
    "--bg-100": "220 16% 22%",
    "--bg-200": "221 16% 25%",
    "--bg-300": "219 17% 32%",
    "--bg-400": "220 16% 36%",
    "--bg-500": "220 16% 40%",
    "--text-000": "218 27% 94%",
    "--text-100": "218 27% 92%",
    "--text-200": "219 28% 88%",
    "--text-300": "220 20% 78%",
    "--text-400": "220 16% 65%",
    "--text-500": "220 14% 55%",
    "--border-100": "220 16% 40%",
    "--border-200": "220 16% 36%",
    "--border-300": "219 17% 32%",
    "--border-400": "221 16% 28%",
    "--accent-main-000": "193 43% 67%",
    "--accent-main-100": "193 43% 62%",
    "--accent-main-200": "193 43% 55%",
    "--accent-secondary-000": "210 34% 63%",
    "--accent-secondary-100": "210 34% 58%",
    "--accent-secondary-200": "213 32% 52%",
    "--accent-pro-000": "311 20% 63%",
    "--accent-pro-100": "311 20% 58%",
    "--accent-pro-200": "311 20% 52%",
    "--danger-000": "354 42% 56%",
    "--danger-100": "354 42% 52%",
    "--danger-200": "354 42% 46%",
    "--oncolor-100": "218 27% 94%",
    "--claude-background-color": "#2E3440",
    "--claude-foreground-color": "#D8DEE9"
  },
  "customCss": [
    "body { background-color: hsl(var(--bg-100)) !important; }",
    "/* 硬编码浅色底(#faf9f5)兜底,变量覆盖不到的内联样式 */",
    "[style*='#faf9f5'], [style*='#FAF9F5'] { background-color: hsl(var(--bg-100)) !important; }",
    "::selection { background-color: hsla(193, 43%, 67%, 0.35); }"
  ]
}
