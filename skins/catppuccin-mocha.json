    "--bg-300": "237 16% 23%",
    "--bg-400": "234 13% 31%",
    "--bg-500": "233 12% 39%",
    "--text-000": "226 64% 88%",
    "--text-100": "226 64% 88%",
    "--text-200": "227 35% 80%",
    "--text-300": "228 24% 72%",
    "--text-400": "230 13% 55%",
    "--text-500": "231 11% 47%",
    "--border-100": "233 12% 39%",
    "--border-200": "234 13% 31%",
    "--border-300": "237 16% 23%",
    "--border-400": "240 21% 20%",
    "--accent-main-000": "267 84% 81%",
